{
  "name": "urlcv/branded-qr-code-generator",
  "version": "dev-main",
  "description": "Branded QR Code Generator — customise, preview, and download QR codes with live scanability checks.",
  "type": "library",
  "license": "MIT",
  "keywords": ["qr-code", "qr", "generator", "branded", "marketing"],
  "homepage": "https://urlcv.com/tools/branded-qr-code-generator",
  "authors": [{ "name": "URLCV", "homepage": "https://urlcv.com" }],
  "require": { "php": "^8.1" },
  "autoload": {
    "psr-4": { "URLCV\\BrandedQrCodeGenerator\\": "src/" }
  },
  "extra": {
    "laravel": {
      "providers": [
        "URLCV\\BrandedQrCodeGenerator\\Laravel\\BrandedQrCodeGeneratorServiceProvider"
      ]
    }
  },
  "config": { "optimize-autoloader": true, "sort-packages": true },
  "minimum-stability": "stable"
}
